# EC2 VPC Endpoint - Basic test
#
# Tests: Gateway VPC Endpoint creation for S3

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = '10.0.0.0/16'

  tags = {
    Environment = 'acceptance-test'
  }
}

let rt = aws.ec2.route_table {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = 'acceptance-test'
  }
}

aws.ec2.vpc_endpoint {
  vpc_id            = vpc.vpc_id
  service_name      = 'com.amazonaws.ap-northeast-1.s3'
  vpc_endpoint_type = aws.ec2.vpc_endpoint.VpcEndpointType.Gateway
  route_table_ids   = [rt.route_table_id]

  tags = {
    Environment = 'acceptance-test'
  }
}
