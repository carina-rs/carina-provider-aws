# EC2 Route Table - Basic test
#
# Tests: route table creation with vpc, tags

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = "10.0.0.0/16"

  tags = {
    Environment = "acceptance-test"
  }
}

aws.ec2.route_table {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = "acceptance-test"
  }
}
