# EC2 Route Table - in-place update test (step 2)
#
# Tests: update tags (in-place update)

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = "10.103.0.0/16"

  tags = {
    Environment = "acceptance-test"
  }
}

aws.ec2.route_table {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = "acceptance-test"
    UpdatedBy   = "carina"
  }
}
