# EC2 Subnet Route Table Association - Basic test
#
# Tests: associating a subnet with a route table

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = '10.0.0.0/16'

  tags = {
    Environment = 'acceptance-test'
  }
}

let subnet = aws.ec2.subnet {
  vpc_id            = vpc.vpc_id
  cidr_block        = '10.0.1.0/24'
  availability_zone = aws.AvailabilityZone.ap_northeast_1a

  tags = {
    Environment = 'acceptance-test'
  }
}

let rt = aws.ec2.route_table {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = 'acceptance-test'
  }
}

aws.ec2.subnet_route_table_association {
  subnet_id      = subnet.subnet_id
  route_table_id = rt.route_table_id
}
