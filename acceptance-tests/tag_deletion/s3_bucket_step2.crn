# S3 Bucket - Tag deletion test (Step 2: Remove one tag)
#
# Same bucket as step 1, but with the "ToBeRemoved" tag deleted.
# S3 uses put_bucket_tagging which replaces the entire tag set,
# so individual tag removal should work. After apply, plan should
# show no changes (idempotent).

provider aws {
  region = aws.Region.ap_northeast_1
}

aws.s3.bucket {
  bucket = 'carina-acc-test-aws-tag-del'

  versioning_status = aws.s3.bucket.VersioningStatus.Enabled

  tags = {
    Environment = 'acceptance-test'
  }
}
