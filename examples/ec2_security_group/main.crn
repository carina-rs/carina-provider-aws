# EC2 Security Group
#
# Creates a security group within a VPC.

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = '10.0.0.0/16'

  tags = {
    Environment = 'example'
  }
}

aws.ec2.security_group {
  group_name  = 'carina-example-sg'
  description = 'Example security group'
  vpc_id      = vpc.vpc_id

  tags = {
    Environment = 'example'
  }
}
