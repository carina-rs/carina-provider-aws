# EC2 Internet Gateway
#
# Creates an internet gateway attached to a VPC.

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = '10.0.0.0/16'

  tags = {
    Environment = 'example'
  }
}

aws.ec2.internet_gateway {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = 'example'
  }
}
